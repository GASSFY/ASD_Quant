# =============================================================================
# ASDQ 默认配置
# =============================================================================
# 使用方式：python main_quant.py --config configs/default.yaml
#          python main_eval.py --config configs/default.yaml
# =============================================================================

# ----- 模型 -----
model: llava_onevision
model_args: "pretrained=your/model-name"
batch_size: "1"
device: null

# ----- 校准数据（量化时使用） -----
calib_data: coco
n_samples: 128
data_path: ""
image_folder: ""
interleave_format: false
few_shot_format: false
text_data_path: ""

# ----- ASD 显著性参数 -----
# ASD = theta1 * K_normalized + theta2 * Psi_normalized
# K = importance_c = ||W[:, c]||^2 * diag(H)_c（跨层可比的绝对显著性）
# Psi = z-score of importance within layer（层内相对突出度）
asd_theta1: 0.8
asd_theta2: 0.2

# ----- 混合精度（ASD 驱动：全局比例 + SpQR 风格） -----
# 是否启用混合精度（启用时需校准数据以收集 Hessian 对角）
asd_mixed_precision: true
# 全模型最多该比例的输入通道保留原始精度（所有层一起排序，不是每层各 10%）
asd_high_precision_ratio: 0.1
# 非 outlier 通道使用的量化比特数
asd_low_w_bit: 4

# ----- 量化参数 -----
run_process: true
scale_path: "scale_cache/asdq_llava_7b_w4.pt"
# 权重量化比特数（未启用混合精度时的统一比特数）
w_bit: 4
# 分组大小（SpQR 中一行 x w_group 列为一组）
w_group: 128
pseudo_quant: true

# ----- 评估参数（main_eval.py 使用） -----
tasks: "mmmu_val"
limit: null
output_path: "eval_results"
seed: "0,1234,1234,1234"
gen_kwargs: ""
log_samples: false
verbosity: "INFO"
